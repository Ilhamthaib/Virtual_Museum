<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Vue GL stéréo (à implémenter avec VrGlSurfaceView) -->
    <com.virtualmuseum.vr.VrGlSurfaceView
        android:id="@+id/vr_gl_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- UI de lancement -->
    <LinearLayout
        android:id="@+id/layout_vr_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:id="@+id/tv_vr_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scan_qr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷 Scanner mon casque Cardboard"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_vr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥽 Lancer la VR"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_vr_back"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Retour"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"/>
    </LinearLayout>

</RelativeLayout>