<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Thumbnail -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp">

            <ImageView
                android:id="@+id/iv_artwork_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Miniature de l'œuvre"/>

            <!-- 3D badge -->
            <TextView
                android:id="@+id/tv_has_3d"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:background="#CC1A237E"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="🥽 3D"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- Text info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_artwork_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Titre"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_artwork_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artiste"
                android:textSize="13sp"
                android:textColor="#546E7A"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tv_artwork_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Année"
                android:textSize="12sp"
                android:textColor="#90A4AE"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Favorite badge (right side) -->
        <ImageView
            android:id="@+id/iv_favorite_badge"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_favorite_filled"
            android:tint="@color/colorFavorite"
            android:visibility="gone"
            android:contentDescription="Favori"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
