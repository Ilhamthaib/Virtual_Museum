<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.virtualmuseum">

    <!-- Caméra obligatoire pour ARCore -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- AR optionnel : l'app fonctionne même sans support ARCore -->
    <uses-feature android:name="android.hardware.camera"         android:required="false"/>
    <uses-feature android:name="android.hardware.camera.ar"      android:required="false"/>
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false"/>

    <!-- VR Cardboard -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature android:glEsVersion="0x00020000" android:required="true" />
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="true"/>
    <uses-feature android:name="android.hardware.sensor.gyroscope" android:required="true"/>
    <uses-feature android:name="android.software.vr.mode" android:required="false"/>
    <uses-feature android:name="android.hardware.vr.high_performance" android:required="false"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VirtualMuseum">

        <activity
            android:name=".activities.CategoriesActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.ArtworkListActivity"
            android:exported="false"
            android:parentActivityName=".activities.CategoriesActivity"/>

        <activity
            android:name=".activities.ArtworkDetailsActivity"
            android:exported="false"
            android:parentActivityName=".activities.ArtworkListActivity"/>

        <activity
            android:name=".activities.FavoritesActivity"
            android:exported="false"
            android:parentActivityName=".activities.CategoriesActivity"/>

        <!-- ArViewerActivity : plein écran, pas de rotation forcée -->
        <activity
            android:name=".activities.ArViewerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout"
            android:parentActivityName=".activities.ArtworkDetailsActivity"/>

        <activity
            android:name=".activities.QrCodeCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".activities.VrViewerActivity"/>

        <!-- Activité VR Cardboard -->
        <activity
            android:name=".activities.VrViewerActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|screenLayout|uiMode|navigation"
            android:enableVrMode="@string/gvr_vr_mode_component"
            android:resizeableActivity="false"
            android:parentActivityName=".activities.ArtworkDetailsActivity">
            <intent-filter>
                <category android:name="com.google.intent.category.CARDBOARD" />
            </intent-filter>
        </activity>

        <!-- ARCore optionnel : l'app reste installable sur appareils sans AR -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional"/>

    </application>
</manifest>
